          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Member\",\n  \"email\": \"john.member@example.com\",\n  \"password\": \"StrongPass123\",\n  \"phoneNumber\": \"08000000000\",\n  \"gender\": \"male\",\n  \"outstation\": \"Abuja\",\n  \"dateOfBirth\": \"1992-08-21\"\n}"
            },
            "url": {
              "raw": "{{apiBaseUrl}}/members",
