              "raw": "{{apiBaseUrl}}/members/{{memberId}}/admin",
              "host": ["{{apiBaseUrl}}"],
              "path": ["members", "{{memberId}}", "admin"]
            },
            "description": "Admin-only. Promotes a member to administrator or updates their admin position."
