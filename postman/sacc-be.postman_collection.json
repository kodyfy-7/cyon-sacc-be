{
  "info": {
    "_postman_id": "6f951091-cb68-4ff1-829d-f6f8a72d8387",
    "name": "sacc-be API",
    "description": "Importable Postman collection for the current sacc-be API.\n\nVariables used:\n- {{baseUrl}}: application base URL\n- {{apiBaseUrl}}: API prefix, defaults to {{baseUrl}}/api/v1\n- {{accessToken}}: standard authenticated user token\n- {{adminAccessToken}}: administrator token for admin-protected routes\n- {{refreshToken}}: refresh token from login/register\n- {{memberId}}, {{eventId}}, {{positionId}}: IDs to reuse across requests\n- {{queueKey}}: basic auth password for queue dashboard\n\nNotes:\n- Public event routes: GET /events and GET /events/:eventId\n- Protected member self route: GET /members/me uses normal bearer auth\n- Admin-only routes require an access token whose JWT payload contains adminId\n- Upload endpoint accepts multipart/form-data with file field name: file",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health And Utility",
      "item": [
        {
          "name": "Root Health",
          "request": {
            "method": "GET",
            "header": [],
