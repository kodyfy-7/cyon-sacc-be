                {
                  "key": "token",
                  "value": "{{adminAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/members/{{memberId}}/admin",
              "host": ["{{apiBaseUrl}}"],
              "path": ["members", "{{memberId}}", "admin"]
            },
            "description": "Admin-only. Removes administrator status from the member."
