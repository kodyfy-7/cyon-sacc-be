# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_PORT=3000
APP_NAME=SACC
APP_URL=https://your-domain.com

# ─── Database dialect ───────────────────────────────────────────────────────
DB_CONNECTION=postgres

# ─── Production DB (Supabase) ───────────────────────────────────────────────
# Connection string (for reference):
# postgresql://postgres.xyhtorhrsrioycxbayai:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
PRODUCTION_HOSTNAME=aws-0-eu-west-1.pooler.supabase.com
PRODUCTION_PORT=5432
PRODUCTION_DB_NAME=postgres
PRODUCTION_USERNAME=postgres.xyhtorhrsrioycxbayai
PRODUCTION_PASSWORD=

# ─── Local / Development DB ─────────────────────────────────────────────────
LOCAL_HOSTNAME=127.0.0.1
LOCAL_PORT=5432
LOCAL_DB_NAME=sacc_dev
LOCAL_USERNAME=postgres
LOCAL_PASSWORD=

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Redis (Bull queues) ────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Queue dashboard basic-auth ─────────────────────────────────────────────
QUEUE_KEY=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
